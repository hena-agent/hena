{
  "name": "@hena-dev/web-ui",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/web-ui.d.ts",
      "default": "./dist/web-ui.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.build.json && bun build ./src/web-ui.ts --outdir ./dist --target bun --format esm --packages external --sourcemap=external",
    "clean": "rm -rf dist coverage",
    "test": "bun --bun vitest run",
    "test:coverage": "bun --bun vitest run --coverage",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "vitest": "4.1.8"
  }
}
