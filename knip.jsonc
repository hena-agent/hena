{
  "$schema": "https://unpkg.com/knip/schema.json",
  "workspaces": {
    "packages/app": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/cli": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/client": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/core": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/db": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/desktop": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/server": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/web": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    }
  }
}
