engine biome(1.0)
language js(typescript, jsx)

or {
    JsExportFromClause() as $export,
    JsExportNamedFromClause() as $export
} where {
    register_diagnostic(
        span = $export,
        message = "Do not re-export from another module. Import from the source module directly instead.",
        severity = "error"
    )
}
