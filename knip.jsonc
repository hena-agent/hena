{
  "$schema": "https://unpkg.com/knip/schema.json",
  "workspaces": {
    ".": {
      "entry": ["e2e/vitest.config.ts"],
      "project": ["e2e/**/*.ts"]
    },
    "packages/client": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/core": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/extensions": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/hena": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/web-ui": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    }
  }
}
