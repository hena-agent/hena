engine biome(1.0)
language js(typescript, jsx)

or {
    JsClassDeclaration() as $class,
    JsClassExpression() as $class,
    JsClassExportDefaultDeclaration() as $class
} where {
    register_diagnostic(
        span = $class,
        message = "Do not use TypeScript class syntax. Use functions and plain objects instead.",
        severity = "error"
    )
}
