{
  "$schema": "https://unpkg.com/knip/schema.json",
  "workspaces": {
    "packages/client": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/core": {
      "entry": ["src/index.ts"],
      "ignoreExportsUsedInFile": true,
      "project": ["src/**/*.ts"]
    },
    "packages/extensions": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/hena": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/web-ui": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    }
  }
}
