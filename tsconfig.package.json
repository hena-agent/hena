{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "${configDir}/.tsbuildinfo/typecheck.tsbuildinfo"
  },
  "include": ["${configDir}/src/**/*.ts"],
  "exclude": ["${configDir}/coverage", "${configDir}/dist"]
}
